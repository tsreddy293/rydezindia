# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_secret_key

# Production site URL (required for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://rydezindia.com

# Google Maps — enable Places API + Directions API + Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_browser_restricted_google_maps_key
GOOGLE_MAPS_API_KEY=your_server_restricted_google_maps_key

# Optional — for npm run db:migrate:vehicles (Supabase → Settings → Database → URI)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# OTP — used to hash OTPs and connect SMS provider
OTP_SECRET=replace_with_long_random_secret

# SMS (MSG91, Twilio, etc.)
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_URL=

# Email (Resend, SendGrid, etc.)
EMAIL_API_KEY=
EMAIL_FROM=noreply@rydezindia.com

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# Cron job secret for document expiry alerts
CRON_SECRET=replace_with_random_secret
